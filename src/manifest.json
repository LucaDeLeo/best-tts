{
  "manifest_version": 3,
  "name": "Best TTS",
  "version": "0.1.0",
  "description": "High-quality local TTS",
  "permissions": ["offscreen", "storage", "activeTab", "scripting", "contextMenus", "notifications", "sidePanel"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "_comment_csp": "wasm-unsafe-eval is required for ONNX Runtime WASM inference (Kokoro TTS model). Without it, WebAssembly.instantiate fails in extension pages.",
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*.wasm", "assets/*.mjs"],
      "matches": ["<all_urls>"]
    }
  ]
}
